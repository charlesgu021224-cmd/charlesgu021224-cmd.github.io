    <section id="rna-seq" class="code-card">
      <h2>1. Differential Expression Analysis with DESeq2</h2>
      <p>
        <strong>Introduction:</strong> This workflow imports count data, builds a DESeq2 dataset,
        runs differential expression analysis, and exports significant genes. It is useful for bulk RNA-seq projects.
      </p>
      <div class="code-meta">
        <span class="tag">R</span>
        <span class="tag">DESeq2</span>
        <span class="tag">RNA-seq</span>
      </div>
      <pre><code>library(DESeq2)

count_matrix <- read.csv("counts.csv", row.names = 1)
meta <- read.csv("metadata.csv")

coldata <- data.frame(
  row.names = colnames(count_matrix),
  condition = meta$condition
)

dds <- DESeqDataSetFromMatrix(
  countData = count_matrix,
  colData = coldata,
  design = ~ condition
)

dds <- DESeq(dds)
res <- results(dds)
res_ordered <- res[order(res$padj), ]
write.csv(as.data.frame(res_ordered), "DEG_results.csv")</code></pre>
